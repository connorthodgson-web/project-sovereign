# =========================
# PROJECT SOVEREIGN VPS ENV
# =========================
# Copy this file to /opt/project-sovereign/.env on the VPS.
# Never commit real secrets.
# Enable integrations one at a time after testing.

# =========================
# CORE MODEL / LLM
# =========================
OPENAI_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL_TIER=3
OPENROUTER_API_KEY=
ESCALATION_ENABLED=true

# =========================
# SLACK
# =========================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_APP_TOKEN=

# =========================
# DASHBOARD / CORS
# =========================
CORS_ALLOWED_ORIGINS=https://REPLACE_WITH_VERCEL_URL

# =========================
# REMINDERS / SCHEDULER
# =========================
REMINDERS_ENABLED=true
SCHEDULER_BACKEND=apscheduler
SCHEDULER_TIMEZONE=America/New_York

# =========================
# MEMORY
# =========================
# Keep Zep disabled/local until an API key exists.
MEMORY_BACKEND=local
MEMORY_PROVIDER=local
ZEP_API_KEY=
ZEP_BASE_URL=
ZEP_USER_ID=
ZEP_THREAD_ID=

# =========================
# BROWSER / REMOTE WORKER
# =========================
# Keep browser disabled on VPS until tested.
# Preferred future architecture:
# VPS CEO delegates heavy browser tasks to a home-computer worker.
BROWSER_ENABLED=false
BROWSER_BACKEND_MODE=remote_worker
BROWSER_USE_ENABLED=false
BROWSER_USE_API_KEY=
BROWSER_SAVE_SCREENSHOTS=true
BROWSER_WORKER_MODE=remote
BROWSER_WORKER_URL=
BROWSER_WORKER_SHARED_SECRET=

# =========================
# RESEARCH / SEARCH
# =========================
# Lightweight research can run on VPS if configured.
SEARCH_ENABLED=false
WEB_SEARCH_ENABLED=false
SEARCH_PROVIDER=
SEARCH_API_KEY=

# =========================
# CODEX CLI
# =========================
# Keep disabled until Codex CLI is installed/authenticated on VPS.
CODEX_CLI_ENABLED=false
CODEX_CLI_COMMAND=codex
CODEX_CLI_WORKSPACE_ROOT=/opt/project-sovereign
CODEX_CLI_TIMEOUT_SECONDS=900
CODEX_CLI_AUTO_MODE=true

# =========================
# GOOGLE CALENDAR
# =========================
# Keep disabled until credential/token files exist on VPS.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_PATH=/opt/project-sovereign/secrets/google_calendar_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=/opt/project-sovereign/secrets/google_calendar_token.json
GOOGLE_CALENDAR_SCOPES=

# =========================
# GMAIL
# =========================
# Keep disabled until credential/token files exist on VPS.
GMAIL_ENABLED=false
GMAIL_CREDENTIALS_PATH=/opt/project-sovereign/secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=/opt/project-sovereign/secrets/gmail_token.json
GMAIL_SCOPES=

# =========================
# GOOGLE TASKS
# =========================
# Keep disabled until credential/token files exist on VPS.
GOOGLE_TASKS_ENABLED=false
GOOGLE_TASKS_CREDENTIALS_PATH=/opt/project-sovereign/secrets/google_tasks_credentials.json
GOOGLE_TASKS_TOKEN_PATH=/opt/project-sovereign/secrets/google_tasks_token.json
GOOGLE_TASKS_SCOPES=
GOOGLE_TASKS_LIST_STUDY=

# =========================
# TELEGRAM
# =========================
TELEGRAM_BOT_TOKEN=

CORS_ALLOWED_ORIGINS=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
MODEL_ROUTING_ENABLED=false
MODEL_TIER_1=
MODEL_TIER_2=
MODEL_TIER_3=
MODEL_DEFAULT_TIER=2
MODEL_ESCALATION_ENABLED=true
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL_TIER_3=
FRONTIER_MODEL_PROVIDER=
FRONTIER_MODEL_API_KEY=
FRONTIER_MODEL_NAME=
OPENAI_AGENTS_ENABLED=false
OPENAI_AGENTS_API_KEY=

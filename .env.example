# =========================
# PROJECT SOVEREIGN LOCAL DEV ENV
# =========================
# This file is a safe developer example.
# Copy values into a local ignored .env for development only.
# For VPS production copy/paste, use env/vps.env.template instead.
# Real secrets live only in local .env files, /opt/project-sovereign/.env,
# GitHub repository secrets, or Vercel environment variables.

# =========================
# APP / LOCAL DEV
# =========================
APP_NAME=Project Sovereign
ENVIRONMENT=development
API_PREFIX=
WORKSPACE_ROOT=workspace

# =========================
# CORE MODEL / LLM
# =========================
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL_TIER=3
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_MODEL_TIER1=google/gemini-2.0-flash-001
OPENROUTER_MODEL_TIER2=openai/gpt-4o
OPENROUTER_MODEL_TIER3=openai/gpt-5.5
MODEL_ROUTING_ENABLED=true
MODEL_TIER_1=
MODEL_TIER_2=
MODEL_TIER_3=
MODEL_DEFAULT_TIER=2
ESCALATION_ENABLED=true
MODEL_ESCALATION_ENABLED=true
OPENAI_MODEL_TIER_3=
FRONTIER_MODEL_PROVIDER=
FRONTIER_MODEL_API_KEY=
FRONTIER_MODEL_NAME=
OPENAI_AGENTS_ENABLED=false
OPENAI_AGENTS_API_KEY=
MANUS_ENABLED=false
MANUS_API_KEY=

# =========================
# SLACK
# =========================
SLACK_ENABLED=true
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_APP_TOKEN=

# =========================
# DASHBOARD / CORS
# =========================
# Local development can leave this blank.
# VPS production should use the real Vercel origin in env/vps.env.template.
CORS_ALLOWED_ORIGINS=

# =========================
# REMINDERS / SCHEDULER
# =========================
REMINDERS_ENABLED=true
SCHEDULER_BACKEND=apscheduler
SCHEDULER_TIMEZONE=America/New_York

# =========================
# MEMORY
# =========================
MEMORY_BACKEND=local
MEMORY_PROVIDER=local
CHROMA_PATH=
CHROMA_COLLECTION_NAME=sovereign_memory
CHROMA_MAX_DISTANCE=1.35
ZEP_API_KEY=
ZEP_BASE_URL=
ZEP_USER_ID=sovereign-default-user
ZEP_THREAD_ID=sovereign-default-thread
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SEMANTIC_RETRIEVAL_ENABLED=false
RETRIEVAL_BACKEND=
RETRIEVAL_URL=
RETRIEVAL_API_KEY=
EMBEDDINGS_MODEL=

# =========================
# BROWSER / REMOTE WORKER
# =========================
# Keep heavy browser execution disabled until the target runtime is tested.
# Future production should prefer a home-computer browser worker over VPS browser execution.
BROWSER_ENABLED=false
BROWSER_BACKEND_MODE=remote_worker
BROWSER_USE_ENABLED=false
BROWSER_USE_API_KEY=
BROWSER_HEADLESS=true
BROWSER_VISIBLE=false
BROWSER_SHOW_WINDOW=false
BROWSER_BASE_URL=
BROWSER_SAVE_SCREENSHOTS=true
BROWSER_WORKER_MODE=remote
BROWSER_WORKER_URL=
BROWSER_WORKER_SHARED_SECRET=

# =========================
# RESEARCH / SEARCH
# =========================
SEARCH_ENABLED=false
WEB_SEARCH_ENABLED=false
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_TIMEOUT_SECONDS=30
GEMINI_SEARCH_MODEL=google/gemini-2.5-flash

# =========================
# CODEX CLI
# =========================
CODEX_CLI_ENABLED=false
CODEX_CLI_COMMAND=codex
CODEX_CLI_WORKSPACE_ROOT=
CODEX_CLI_TIMEOUT_SECONDS=900
CODEX_CLI_AUTO_MODE=false

# =========================
# GOOGLE CALENDAR
# =========================
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_PATH=secrets/google_calendar_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=secrets/google_calendar_token.json
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
CALENDAR_ID=primary

# =========================
# GMAIL
# =========================
GMAIL_ENABLED=false
GMAIL_CREDENTIALS_PATH=secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=secrets/gmail_token.json
GMAIL_SCOPES=https://mail.google.com/
EMAIL_ENABLED=false
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# =========================
# GOOGLE TASKS
# =========================
GOOGLE_TASKS_ENABLED=false
GOOGLE_TASKS_CREDENTIALS_PATH=secrets/google_tasks_credentials.json
GOOGLE_TASKS_TOKEN_PATH=secrets/google_tasks_token.json
GOOGLE_TASKS_SCOPES=https://www.googleapis.com/auth/tasks
GOOGLE_TASKS_LIST_STUDY=
GOOGLE_TASKS_LIST_ID=@default

# =========================
# TELEGRAM / FUTURE COMMS
# =========================
TELEGRAM_BOT_TOKEN=
MESSAGING_ENABLED=false
MESSAGING_PROVIDER=
MESSAGING_API_KEY=
MESSAGING_DEFAULT_CHANNEL=
VOICE_ENABLED=false
VOICE_API_KEY=
CALL_PROVIDER=
CALL_API_KEY=

# =========================
# OPTIONAL OPENCLAW
# =========================
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=

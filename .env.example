MANUS_API_KEY=
CODEX_CLI_ENABLED=false
CODEX_CLI_COMMAND=codex
CODEX_CLI_WORKSPACE_ROOT=
CODEX_CLI_TIMEOUT_SECONDS=900
CODEX_CLI_AUTO_MODE=false

# Supabase project URL and keys for future persistence and auth work.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SEMANTIC_RETRIEVAL_ENABLED=false
RETRIEVAL_BACKEND=
RETRIEVAL_URL=
RETRIEVAL_API_KEY=
EMBEDDINGS_MODEL=
SEARCH_ENABLED=false
SEARCH_PROVIDER=
SEARCH_TIMEOUT_SECONDS=30
GEMINI_SEARCH_MODEL=google/gemini-2.5-flash
MEMORY_PROVIDER=local
CHROMA_PATH=
CHROMA_COLLECTION_NAME=sovereign_memory
CHROMA_MAX_DISTANCE=1.35
MEMORY_BACKEND=local
ZEP_API_KEY=
ZEP_BASE_URL=
ZEP_USER_ID=sovereign-default-user
ZEP_THREAD_ID=sovereign-default-thread

# Slack bot token for app runtime messaging/events.
SLACK_BOT_TOKEN=
# Slack Socket Mode app token for the interface process.
SLACK_APP_TOKEN=
# Slack request signature verification secret.
SLACK_SIGNING_SECRET=
# Slack OAuth app credentials for future install flows.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_ENABLED=true

# Telegram bot token for future bot workflows.
TELEGRAM_BOT_TOKEN=
MESSAGING_ENABLED=false
MESSAGING_PROVIDER=
MESSAGING_API_KEY=
MESSAGING_DEFAULT_CHANNEL=

# Voice provider credential for future STT/TTS support.
VOICE_API_KEY=
VOICE_ENABLED=false
CALL_PROVIDER=
CALL_API_KEY=

# Browser automation provider or hosted browser execution credential.
BROWSER_USE_ENABLED=false
BROWSER_USE_API_KEY=
BROWSER_BACKEND_MODE=auto
BROWSER_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_VISIBLE=false
BROWSER_SHOW_WINDOW=false
BROWSER_BASE_URL=
BROWSER_SAVE_SCREENSHOTS=on_failure

# Future email adapter settings.
EMAIL_ENABLED=false
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# Gmail settings for the unified Communications Agent.
GMAIL_ENABLED=false
GMAIL_CREDENTIALS_PATH=secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=secrets/gmail_token.json
GMAIL_SCOPES=https://mail.google.com/

# Google Calendar settings for the Scheduling / Personal Ops Agent.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_PATH=secrets/credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=secrets/token.json
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
CALENDAR_ID=primary

# Google Tasks settings for the Scheduling / Personal Ops Agent.
GOOGLE_TASKS_ENABLED=false
GOOGLE_TASKS_CREDENTIALS_PATH=secrets/google_tasks_credentials.json
GOOGLE_TASKS_TOKEN_PATH=secrets/google_tasks_token.json
GOOGLE_TASKS_SCOPES=https://www.googleapis.com/auth/tasks
GOOGLE_TASKS_LIST_ID=@default

# Future reminder/scheduler settings.
# Set these for live one-time reminders in the current Slack-first runtime.
REMINDERS_ENABLED=true
SCHEDULER_BACKEND=apscheduler
SCHEDULER_TIMEZONE=America/New_York

# Optional OpenClaw runtime bridge settings.
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
